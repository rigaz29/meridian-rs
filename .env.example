# Meridian RS environment template
# Copy to `.env` for local development, or to `~/.meridian/.env` for the default runtime profile.
# Never commit real private keys or API keys.

# ── Safety ───────────────────────────────────────────────────────
# Keep true while testing. Live transaction submission should only be enabled intentionally.
DRY_RUN=true

# ── Wallet / Private Key ─────────────────────────────────────────
# Original JS-compatible private key env. Supported formats:
# - Base58 Solana keypair string, e.g. output from keypair.to_base58_string()
# - Solana CLI JSON byte array, e.g. [1,2,3,...]
WALLET_PRIVATE_KEY=

# Optional Rust-specific alias. Leave empty if WALLET_PRIVATE_KEY is set.
MERIDIAN_WALLET_PRIVATE_KEY=

# Public wallet address used for balance/position reads.
MERIDIAN_WALLET=

# ── RPC / Helius ─────────────────────────────────────────────────
# Original JS-compatible RPC env. Used by the Rust config loader.
RPC_URL=https://api.mainnet-beta.solana.com

# Preferred when using Helius.
HELIUS_RPC_URL=
HELIUS_API_KEY=

# ── LLM / OpenAI-compatible provider ─────────────────────────────
# OpenRouter example:
LLM_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=

# Generic OpenAI-compatible fallback. If set, this is also accepted.
LLM_API_KEY=

# Model aliases are mapped into the Rust runtime config.
LLM_MODEL=openai/gpt-4o-mini
MANAGEMENT_MODEL=
SCREENING_MODEL=
GENERAL_MODEL=

# ── Runtime state ────────────────────────────────────────────────
# Defaults to ~/.meridian when unset.
MERIDIAN_DATA_DIR=
# Optional override for the position state file only.
MERIDIAN_STATE_PATH=

# ── Optional integrations ────────────────────────────────────────
JUPITER_API_KEY=
JUPITER_REFERRAL_ACCOUNT=
JUPITER_REFERRAL_FEE_BPS=50
AGENT_MERIDIAN_API_URL=
PUBLIC_API_KEY=
LPAGENT_API_KEY=
# Optional Discord signal listener/importer compatibility. Keep tokens local and never commit values.
DISCORD_USER_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CHANNEL_IDS=
DISCORD_MIN_FEES_SOL=5
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
